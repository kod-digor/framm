# Variables obligatoires
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_PROJECT_ID=
ADMIN_PASSWORD=
BUREAU_ADMIN_EMAIL=

# Optionnel — clé SSH (auto-détectée depuis ~/.ssh/ si absente)
# SSH_PUBLIC_KEY=ssh-ed25519 AAAA...

# Optionnel — DNS (auto-détecté au bootstrap)
# DNS_ENABLED=true

# Optionnel — domaine app.bzh
# APP_BZH_ENABLED=false

# SMTP des alertes : provisionné AUTOMATIQUEMENT via Scaleway TEM quand le
# DNS est géré par Scaleway (terraform/environments/prod/alerting.tf).
# Ne renseignez ces variables que pour utiliser un autre SMTP (Brevo, etc.) —
# elles sont alors prioritaires sur TEM.
# ALERT_SMTP_HOST=
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=
# ALERT_SMTP_PASSWORD=
# ALERT_SMTP_FROM=
