# Variables obligatoires
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_PROJECT_ID=
ADMIN_PASSWORD=
BUREAU_ADMIN_EMAIL=

# Optionnel — clé SSH (auto-détectée depuis ~/.ssh/ si absente)
# SSH_PUBLIC_KEY=ssh-ed25519 AAAA...

# DNS prod : laisser true (tf-apply défaut true) — false planifie la destruction des records
DNS_ENABLED=true

# Optionnel — domaine app.bzh
# APP_BZH_ENABLED=false

# SMTP des alertes : provisionné AUTOMATIQUEMENT via Scaleway TEM quand le
# DNS est géré par Scaleway (terraform/environments/prod/alerting.tf).
# Ne renseignez ces variables que pour utiliser un autre SMTP (Brevo, etc.) —
# elles sont alors prioritaires sur TEM.
# ALERT_SMTP_HOST=
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=
# ALERT_SMTP_PASSWORD=
# ALERT_SMTP_FROM=

# PayPlug — facturation CB à l'inscription (apps/web)
# PAYPLUG_SECRET_KEY=sk_test_...
# PAYPLUG_RETURN_URL=https://app.kod-digor.bzh/dashboard/billing?paid=1
# PAYPLUG_WEBHOOK_URL=https://app.kod-digor.bzh/api/webhooks/payplug
# PAYPLUG_SIGNUP_AMOUNT_CENTS=100

# IPv4 autorisées sur l endpoint public PostgreSQL (dev local, sans tunnel)
# RDB_ALLOWED_IPS=203.0.113.10

# Google Cloud Console → OAuth 2.0 Client
GOOGLE_MIGRATION_CLIENT_ID=...
GOOGLE_MIGRATION_CLIENT_SECRET=...
# Redirect URI : {AUTH_URL}/api/migration/oauth/google/callback

# Azure Portal → App registrations
MICROSOFT_MIGRATION_CLIENT_ID=...
MICROSOFT_MIGRATION_CLIENT_SECRET=...
# Redirect URI : {AUTH_URL}/api/migration/oauth/microsoft/callback

# Cible IMAP Stalwart (worker)
MIGRATION_STALWART_IMAP_HOST=mail.kod-digor.bzh
MIGRATION_STALWART_IMAP_PORT=993
IMAPSYNC_PATH=/usr/bin/imapsync   # optionnel
# Secret JWT NextAuth stable en dev (bin/framm sync-dev-env le réutilise si .env.local absent)
# DEV_AUTH_SECRET=dev-secret-change-in-production
