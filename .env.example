# Variables obligatoires
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_PROJECT_ID=
ADMIN_PASSWORD=
BUREAU_ADMIN_EMAIL=

# Optionnel — clé SSH (auto-détectée depuis ~/.ssh/ si absente)
# SSH_PUBLIC_KEY=ssh-ed25519 AAAA...

# Optionnel — DNS (auto-détecté au bootstrap)
# DNS_ENABLED=true

# Optionnel — domaine app.bzh
# APP_BZH_ENABLED=false

# Recommandé — SMTP pour l'envoi des alertes Grafana/Alertmanager.
# Sans ces variables, les pannes ne sont notifiées nulle part.
# Un compte SMTP externe (ex: Scaleway TEM, Brevo) est préférable au serveur
# mail de la plateforme : si la VM mail tombe, l'alerte doit quand même partir.
# ALERT_SMTP_HOST=
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=
# ALERT_SMTP_PASSWORD=
# ALERT_SMTP_FROM=
