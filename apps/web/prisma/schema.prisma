generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUREAU
  ASSOC_ADMIN
  ASSOC_MEMBER
}

enum OrganizationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DomainStatus {
  PENDING_DNS
  VERIFIED
  ACTIVE
}

enum WalletTransactionType {
  DEPOSIT
  CONSUMPTION
  RECHARGE
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  presentation       String
  status             OrganizationStatus   @default(PENDING)
  rejectReason       String?
  approvedAt         DateTime?
  walletBalanceCents Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  members            OrganizationMember[]
  domains            Domain[]
  mailboxes          Mailbox[]
  emailAliases       EmailAlias[]
  usageSnapshots     UsageSnapshot[]
  walletTransactions WalletTransaction[]
  auditLogs          AuditLog[]
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  memberships  OrganizationMember[]
  auditLogs    AuditLog[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           UserRole
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

model Domain {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  fqdn             String
  status           DomainStatus @default(PENDING_DNS)
  dnsRecordsJson   Json?
  stalwartDomainId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  mailboxes        Mailbox[]

  @@unique([organizationId, fqdn])
}

model Mailbox {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  domainId          String
  domain            Domain       @relation(fields: [domainId], references: [id])
  address           String       @unique
  displayName       String?
  stalwartAccountId String?
  /// Mot de passe boîte chiffré (AES-GCM) pour SSO webmail — jamais en clair
  credentialsEnc    String?
  /// Limite stockage en octets ; null = illimité (défaut serveur Stalwart)
  quotaBytes        BigInt?
  usedBytes         BigInt       @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model EmailAlias {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  source          String
  destination     String
  stalwartAliasId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([organizationId, source])
}

model UsageSnapshot {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  metric         String
  value          BigInt
  recordedAt     DateTime     @default(now())

  @@index([organizationId, recordedAt])
}

model PlatformPricing {
  id                   String   @id @default(cuid())
  sku                  String
  region               String
  storageEurPerGbHour  Float
  storageEurPerGbMonth Float
  source               String
  fetchedAt            DateTime @default(now())

  @@index([fetchedAt])
}

model WalletTransaction {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type              WalletTransactionType
  amountCents       Int
  feeCents          Int                   @default(0)
  balanceAfterCents Int
  monthKey          String?
  description       String?
  createdAt         DateTime              @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, monthKey, type])
}

model AuditLog {
  id             String        @id @default(cuid())
  actorId        String?
  actor          User?         @relation(fields: [actorId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  action         String
  target         String?
  metadata       Json?
  createdAt      DateTime      @default(now())
}
