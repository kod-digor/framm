# Worker migration : Node + imapsync (IMAP source → Stalwart).
# imapsync s'exécute dans le pod worker (spawn depuis migration-worker.ts).
FROM node:22-bookworm-slim
WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends imapsync ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json* ./
COPY prisma ./prisma
RUN npm ci
COPY . .
RUN npx prisma generate

ENV IMAPSYNC_PATH=/usr/bin/imapsync

CMD ["npm", "run", "worker"]
