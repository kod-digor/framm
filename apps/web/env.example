# DB locale (docker compose -f deploy/docker/docker-compose.dev.yml up -d)
DATABASE_URL=postgresql://framm:framm@localhost:5432/framm

# DB prod en dev : bin/framm sync-dev-env (connexion TLS directe, sans tunnel)
# DATABASE_URL=postgresql://framm:<DB_PASSWORD>@<RDB_PUBLIC_HOST>:<RDB_PUBLIC_PORT>/framm?sslmode=require
# Fallback si IP non autorisée : bin/framm db-tunnel puis 127.0.0.1:5433
# Secret JWT NextAuth — doit rester stable entre les redémarrages dev.
# sync-dev-env conserve la valeur existante ; sinon DEV_AUTH_SECRET dans .env racine.
AUTH_SECRET=dev-secret-change-in-production
AUTH_URL=http://localhost:3000
PLATFORM_DOMAINS=kod-digor.bzh
WEBMAIL_URL=https://webmail.kod-digor.bzh
STALWART_URL=https://mail.kod-digor.bzh
# Relais SMTP sortant Scaleway TEM (envoi health-check redirection e-mail)
OUTBOUND_SMTP_RELAY_HOST=smtp.tem.scaleway.com
OUTBOUND_SMTP_RELAY_PORT=2587
OUTBOUND_SMTP_RELAY_USER=
OUTBOUND_SMTP_RELAY_SECRET=
# Client JMAP natif (fallback) au lieu de l'iframe Bulwark proxy
# WEBMAIL_USE_NATIVE_JMAP=true
STALWART_API_KEY=
# Chiffrement au repos — obligatoire en production
# Dev : fallback automatique sur config/stalwart-dev-public.pem
# Prod : STALWART_PLATFORM_PGP_PUBLIC_KEY (PEM, \\n pour les retours ligne) ou STALWART_PLATFORM_PGP_PUBLIC_KEY_B64
# STALWART_ENCRYPTION_PUBLIC_KEY_ID=  # alternative : ID clé publique déjà enregistrée dans Stalwart
S3_ENDPOINT=https://s3.fr-par.scw.cloud
S3_REGION=fr-par
S3_BUCKET_UPLOADS=
S3_ACCESS_KEY=
S3_SECRET_KEY=
BUREAU_ADMIN_EMAIL=
BUREAU_ADMIN_PASSWORD=
# PayPlug — CB obligatoire à l'inscription
# PAYPLUG_SECRET_KEY=sk_test_...
# PAYPLUG_RETURN_URL=http://localhost:3000/dashboard/billing?paid=1
# PAYPLUG_WEBHOOK_URL=http://localhost:3000/api/webhooks/payplug
# PAYPLUG_SIGNUP_AMOUNT_CENTS=100

# Migration mail (OAuth Google/Microsoft + imapsync IMAP→Stalwart)
# Source OAuth : .env à la racine du dépôt (.env.example) — chargé automatiquement par Next.js
# (load-root-env.ts). apps/web/.env.local surcharge si besoin (ex. AUTH_URL local).
# bin/framm sync-dev-env régénère .env.local (conserve AUTH_SECRET) sans écraser le .env racine.
# pnpm db:seed charge automatiquement apps/web/.env.local (voir load-dev-env.ts).
# Obligatoire pour OAuth : AUTH_SECRET (ci-dessus) + AUTH_URL (redirect URI de base)
# NEXTAUTH_URL n'est pas utilisé pour la migration — seule AUTH_URL compte
#
# Google Cloud Console — activer dans APIs & Services → Library :
#   Gmail API, People API, Google Calendar API
# Scopes OAuth demandés par Framm (consent screen / auth URL) :
#   https://mail.google.com/
#   https://www.googleapis.com/auth/gmail.readonly
#   https://www.googleapis.com/auth/contacts.readonly
#   https://www.googleapis.com/auth/calendar.readonly
#   email, openid
# → GOOGLE_MIGRATION_CLIENT_ID / GOOGLE_MIGRATION_CLIENT_SECRET dans .env racine
# Redirect URI dev : http://localhost:3000/api/migration/oauth/google/callback
# Redirect URI prod : https://kod-digor.bzh/api/migration/oauth/google/callback
#
# Azure Portal → App registrations — permissions déléguées :
#   Microsoft Graph : Mail.Read, Contacts.Read, Calendars.Read
#   Office 365 Exchange Online : IMAP.AccessAsUser.All
#   (+ offline_access, email, openid — ajoutés automatiquement au consentement)
# → MICROSOFT_MIGRATION_CLIENT_ID / MICROSOFT_MIGRATION_CLIENT_SECRET dans .env racine
# Redirect URI dev : http://localhost:3000/api/migration/oauth/microsoft/callback
# Redirect URI prod : https://kod-digor.bzh/api/migration/oauth/microsoft/callback
#
# Worker imapsync (optionnel, .env racine) :
# MIGRATION_STALWART_IMAP_HOST / MIGRATION_STALWART_IMAP_PORT / IMAPSYNC_PATH
# IMAPSYNC_MAX_PARALLEL=4              # dossiers synchronisés en parallèle (1–8, défaut 4)
# IMAPSYNC_MAX_BYTES_PER_SECOND=       # limite débit optionnelle (ex. 5000000 pour Gmail)
# MIGRATION_WORKER_CONCURRENCY=1       # migrations simultanées par replica worker (1–4)
