{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "argocd": {
    "fileMatch": ["^k8s/(argocd|templates)/.+\\.ya?ml$"]
  },
  "kustomize": {
    "fileMatch": ["^k8s/.+kustomization\\.ya?ml$"]
  },
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchPaths": ["apps/web/**"],
      "groupName": "framm-web-deps"
    },
    {
      "matchManagers": ["docker-compose", "dockerfile"],
      "groupName": "framm-docker"
    },
    {
      "description": "Patchs Docker auto-mergés (CI verte requise) puis déployés par le workflow Deploy — mineures/majeures restent en PR à valider",
      "matchManagers": ["docker-compose", "dockerfile"],
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true
    }
  ]
}
